{
  "include": [
    "lib/**/*",
    "test/**/*",
    "eslint.config.js",
    "tsdown.config.ts"
  ],
  "types": [ "node" ],
  "compilerOptions": {
    "rootDir": ".",
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowSyntheticDefaultImports": true,
    "allowImportingTsExtensions": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true,
    "erasableSyntaxOnly": true,
    "allowJs": true,
    "checkJs": true,
    "stripInternal": true,
    "noEmit": true,
    "emitDeclarationOnly": false,
    "noEmitOnError": true,
    "noErrorTruncation": true,
    "outDir": "types",
    "declarationMap": true,
    "composite": true,
    "skipLibCheck": true
  }
}
